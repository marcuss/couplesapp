# Supabase Configuration — DEV
# Proyecto: couplesapp-dev
#
# INSTRUCCIONES PARA OBTENER LOS VALORES:
# 1. Ir a https://supabase.com/dashboard/project/<PROJECT_REF>/settings/api
# 2. Copiar "Project URL" → VITE_SUPABASE_URL
# 3. Copiar "anon public" key → VITE_SUPABASE_ANON_KEY
#
# Tras ejecutar `terraform apply` en terraform/environments/dev/,
# obtener los valores con:
#   terraform output dev_api_url
#   terraform output dev_anon_key
#
# O desde GitHub Actions secrets: SUPABASE_DEV_PROJECT_REF
# y luego via Supabase CLI:
#   supabase projects api-keys --project-ref <DEV_PROJECT_REF>

VITE_SUPABASE_URL=https://<DEV_PROJECT_REF>.supabase.co
VITE_SUPABASE_ANON_KEY=<DEV_ANON_KEY>

# Application Configuration
# Base URL for invitation links (must match your deployment URL)
VITE_APP_URL=http://localhost:5173

# Optional: Analytics
# VITE_ANALYTICS_ID=your_analytics_id

# AWS SES Configuration (reemplaza EmailJS)
# Para las keys reales, ver .env.local (no commitear)
VITE_AWS_SES_ACCESS_KEY_ID=<SES_ACCESS_KEY>
VITE_AWS_SES_SECRET_ACCESS_KEY=<SES_SECRET_KEY>
VITE_AWS_REGION=us-east-1
# FROM temporal (testing): m4rkuz@gmail.com
# FROM definitivo: couplesapp-noreply@nextasy.co (requiere dominio verificado en GoDaddy)
VITE_SES_FROM_EMAIL=m4rkuz@gmail.com
